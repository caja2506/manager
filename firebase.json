{
    "storage": {
        "rules": "storage.rules"
    },
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "functions": [
        {
            "source": "functions",
            "codebase": "default",
            "ignore": [
                "node_modules",
                ".git"
            ]
        }
    ],
    "hosting": {
        "public": "dist",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "headers": [
            {
                "source": "**/*.html",
                "headers": [
                    { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
                ]
            },
            {
                "source": "/index.html",
                "headers": [
                    { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
                ]
            }
        ],
        "rewrites": [
            {
                "source": "/tg-report{,/**}",
                "destination": "/tg-report/index.html"
            },
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    }
}