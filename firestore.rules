rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // IDENTITY MODEL — Dual-Collection Strategy
    // ============================================================
    //
    // The system uses TWO user collections:
    //
    //   users_roles/{uid} → RBAC (admin/editor/viewer)
    //     - Determines Firestore write permissions via getUserRole()
    //     - Managed by RoleContext.jsx + UserAdminPanel
    //
    //   users/{uid} → Operational profile (teamRole, capacity, etc.)
    //     - Determines team function via getTeamRole()
    //     - Bootstrapped on login by RoleContext via userProfileService
    //     - Loaded by AppDataContext as teamMembers
    //
    // See: src/services/userProfileService.js for bootstrap logic
    // ============================================================


    // ============================================================
    // HELPER FUNCTIONS
    // ============================================================

    function getUserRole() {
      return get(/databases/$(database)/documents/users_roles/$(request.auth.uid)).data.role;
    }

    function getTeamRole() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userData != null ? userData.teamRole : null;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isEditor() {
      return isAuthenticated() && getUserRole() in ['admin', 'editor'];
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Engineering roles: manager, team_lead, engineer, technician
    function isManager() {
      return isAuthenticated() && getTeamRole() == 'manager';
    }

    function isTeamLead() {
      return isAuthenticated() && getTeamRole() in ['manager', 'team_lead'];
    }

    function isEngineer() {
      return isAuthenticated() && getTeamRole() in ['manager', 'team_lead', 'engineer'];
    }

    // ============================================================
    // GLOBAL READ RULE
    // Authenticated users can read all collections
    // ============================================================

    match /{collection}/{document=**} {
      allow read: if isAuthenticated();
    }

    // ActivityLog: collectionGroup queries need explicit path matching
    // This enables the cross-task activity timeline page
    match /{path=**}/activityLog/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // WeeklyPlanItems: authenticated users can fully manage their own planning blocks
    // This is placed at global level to ensure it overrides any potential conflicts
    match /weeklyPlanItems/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ============================================================
    // EXISTING COLLECTIONS (preserved — no changes)
    // ============================================================

    // --- users_roles ---
    // Users can create their own role doc (self-registration on first login).
    // Admins can create role docs for other users (register orphan users).
    // Admins can update/delete any role doc.
    match /users_roles/{userId} {
      allow create: if isAuthenticated()
        && (
          // Self-registration: user creates own doc with viewer role
          (request.auth.uid == userId && request.resource.data.role == 'viewer')
          // Admin registration: admin creates doc for another user
          || isAdmin()
        );
      allow update: if isAdmin()
        || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // --- proyectos_bom ---
    match /proyectos_bom/{docId} {
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // --- catalogo_maestro ---
    match /catalogo_maestro/{docId} {
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // --- items_bom ---
    match /items_bom/{docId} {
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // --- marcas, categorias, proveedores ---
    match /marcas/{docId} {
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    match /categorias/{docId} {
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    match /proveedores/{docId} {
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // ============================================================
    // NEW COLLECTIONS — Engineering Management Platform
    // ============================================================

    // --- users (extended profiles) ---
    // Users can create/update their own profile
    // Admins can update any profile (e.g., assign teamRole)
    match /users/{userId} {
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- projects (engineering projects) ---
    // Editors+ can create/update projects
    // Only admins can delete projects
    match /projects/{docId} {
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // --- tasks ---
    // HARDENED: Workflow-controlled fields can ONLY be set by the
    // transitionTaskStatus Cloud Function (Admin SDK bypasses rules).
    // Clients can update non-workflow fields (title, description, etc.)
    // but CANNOT directly change status, completedDate, or reopen fields.
    match /tasks/{docId} {
      allow create: if isEditor();
      allow update: if isAuthenticated()
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['status', 'completedDate', 'completedAt', 'reopenedAt', 'reopenedBy', 'updatedBy']);
      allow delete: if isAdmin();

      // --- activityLog (sub-collection) ---
      // Timeline events for task activity tracking
      match /activityLog/{logId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated();
      }
    }

    // --- subtasks ---
    // Follow same rules as tasks
    match /subtasks/{docId} {
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // --- timeLogs ---
    // Any authenticated user can create their own time logs
    // Users can update their own logs; admins can update any
    // Only admins can delete
    match /timeLogs/{docId} {
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // --- delayCauses (configurable list) ---
    // Only admins can manage delay causes
    match /delayCauses/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- delays ---
    // Any authenticated user can report a delay
    // Creator or admin can update
    // Only admins can delete
    match /delays/{docId} {
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // --- risks ---
    // System-managed (written by Cloud Functions or admin)
    // Read by all authenticated (global read rule)
    match /risks/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- dailyReports ---
    // System-generated, read-only for users
    // Admins can manage
    match /dailyReports/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- notifications ---
    // Users can only update their own notifications (mark as read)
    // System/admin creates notifications
    match /notifications/{docId} {
      allow create: if isAdmin();
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // --- taskTypes ---
    // Admin-managed configuration
    match /taskTypes/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- settings ---
    // Admin-only management
    match /settings/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- auditLogs ---
    // Immutable: only system/admin can create
    // No updates or deletes allowed
    match /auditLogs/{docId} {
      allow create: if isAdmin();
    }
    // --- weeklyPlanItems ---
    // Any authenticated user can plan work (same pattern as tasks)
    match /weeklyPlanItems/{docId} {
      allow create, update, delete: if isAuthenticated();
    }

    // --- taskDependencies ---
    // Any authenticated user can create/manage task dependencies (Gantt linking)
    match /taskDependencies/{docId} {
      allow create, update, delete: if isAuthenticated();
    }

    // ============================================================
    // MANAGEMENT INTELLIGENCE COLLECTIONS
    // ============================================================

    // --- auditFindings ---
    // System-generated by Rule Engine / Cloud Functions / Client Audit
    // Append-only for authenticated users; admin can update/resolve
    // (Cloud Functions use Admin SDK which bypasses rules)
    match /auditFindings/{docId} {
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- auditEvents ---
    // IMMUTABLE audit trail — append-only, no updates, no deletes.
    // Written by Cloud Functions (Admin SDK) and client audit runs.
    // Official schema: eventType, entityType, entityId, userId,
    //                  timestamp, source, correlationId, details
    match /auditEvents/{docId} {
      allow create: if isAuthenticated();
      // NO update or delete — immutable trail
    }

    // --- analyticsSnapshots ---
    // System-generated periodic snapshots
    // Read-only for frontend; written by Cloud Functions
    match /analyticsSnapshots/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- aiInsights ---
    // Gemini-generated insights
    // Read-only for frontend; written by Cloud Functions
    match /aiInsights/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- managementBriefs ---
    // Weekly management summaries generated by Gemini
    // Read-only for frontend; written by Cloud Functions
    match /managementBriefs/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- notifications ---
    // User-scoped notifications. Users can read/update their own (mark as read).
    // Created by Cloud Functions or admin. Delete restricted to admin.
    match /notifications/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // AUTOMATION OPERATIONS & ACCOUNTABILITY FOUNDATION
    // ============================================================
    //
    // All automation collections are admin-only from the client.
    // Cloud Functions (Phase 2) use Admin SDK which bypasses rules.
    // Global read rule above grants authenticated read access.
    //

    // --- automationRoutines ---
    // Admin controls routine definitions (enable/disable, config)
    match /automationRoutines/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- automationRuns ---
    // Written by Cloud Functions; admin can manage from UI
    match /automationRuns/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- automationMetricsDaily ---
    // Written by Cloud Functions; admin can view/manage
    match /automationMetricsDaily/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- operationIncidents ---
    // Authenticated users can create incidents (report blockers)
    // Admin resolves/manages incidents
    match /operationIncidents/{docId} {
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- telegramSessions ---
    // Backend-managed only; admin can inspect from UI
    match /telegramSessions/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- telegramReports ---
    // Backend-managed only
    match /telegramReports/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- telegramEscalations ---
    // Backend-managed only
    match /telegramEscalations/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- telegramBotLogs ---
    // APPEND-ONLY operational log — no updates, no deletes
    match /telegramBotLogs/{docId} {
      allow create: if isAdmin();
      // NO update or delete — append-only traceability
    }

    // --- telegramDeliveries ---
    // Backend-managed only
    match /telegramDeliveries/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // PHASE 4: ANALYTICS ENGINE COLLECTIONS
    // ============================================================
    //
    // All analytics collections are written by Cloud Functions
    // (Admin SDK). Clients can read (via global rule above).
    // Admin can manage from UI.
    //

    // --- operationalKpiSnapshots ---
    match /operationalKpiSnapshots/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- userOperationalScores ---
    match /userOperationalScores/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- routineOperationalScores ---
    match /routineOperationalScores/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- teamOperationalSummaries ---
    match /teamOperationalSummaries/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- operationalRiskFlags ---
    match /operationalRiskFlags/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- operationalRecommendations ---
    match /operationalRecommendations/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- analyticsRefreshLogs ---
    match /analyticsRefreshLogs/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- aiExecutions ---
    // Written by Cloud Functions; admin can inspect
    match /aiExecutions/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // PHASE 5: OPTIMIZATION ENGINE COLLECTIONS
    // ============================================================
    //
    // All optimization collections are written by Cloud Functions
    // (Admin SDK). Clients can read (via global rule above).
    // Admin can manage from UI.
    //

    // --- optimizationOpportunities ---
    match /optimizationOpportunities/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- optimizationSimulations ---
    match /optimizationSimulations/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- operationalPlans ---
    match /operationalPlans/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- appliedRecommendations ---
    match /appliedRecommendations/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- optimizationHistory ---
    // APPEND-ONLY audit trail — no updates, no deletes for traceability
    match /optimizationHistory/{docId} {
      allow create: if isAdmin();
      // NO update or delete — append-only traceability
    }

    // ============================================================
    // TELEGRAM LINK CODES
    // ============================================================

    // --- telegramLinkCodes ---
    match /telegramLinkCodes/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // V5 FOUNDATION COLLECTIONS
    // ============================================================

    // --- milestones ---
    // Editors+ can create/update/delete milestones within projects
    match /milestones/{docId} {
      allow create, update, delete: if isEditor();
    }

    // --- workAreas ---
    // Editors+ can manage work areas within milestones
    // Only admins can delete
    match /workAreas/{docId} {
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // --- workAreaTypes ---
    // Global catalog of work area names (Eléctrica, Mecánica, etc.)
    // Editors+ can manage, admins can delete
    match /workAreaTypes/{docId} {
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // --- milestoneTypes ---
    // Global catalog of milestone types (Setup, Commissioning, etc.)
    // Editors+ can manage, admins can delete
    match /milestoneTypes/{docId} {
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // --- auditTrail ---
    // IMMUTABLE, APPEND-ONLY — no updates, no deletes, EVER
    // Written by Cloud Functions (Admin SDK) and client audit actions
    match /auditTrail/{docId} {
      allow create: if isAuthenticated();
      // NO update or delete — immutable trail
    }

    // --- aiGovernance ---
    // Admin-only: defines AI capability matrix
    match /aiGovernance/{docId} {
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- scoreSnapshots ---
    // Append-only score history for trend analysis
    // Written by system/client on score computation events
    match /scoreSnapshots/{docId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      // NO update or delete — immutable history
    }

  }
}
