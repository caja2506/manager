rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // IDENTITY MODEL — Unified Collection (V5)
    // ============================================================
    //
    // The system uses ONE user collection:
    //
    //   users/{uid} → Unified profile
    //     - rbacRole: RBAC (admin/editor/viewer) — used by getUserRole()
    //     - teamRole: Operational role (manager/team_lead/engineer/technician)
    //     - Bootstrapped on login by RoleContext via userProfileService
    //
    //   users_roles/{uid} → FROZEN (read-only, legacy)
    //     - Kept for backward compatibility, no new writes
    //
    // See: src/services/userProfileService.js for bootstrap logic
    // ============================================================


    // ============================================================
    // HELPER FUNCTIONS
    // ============================================================

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rbacRole;
    }

    function getTeamRole() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userData != null ? userData.teamRole : null;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isEditor() {
      return isAuthenticated() && getUserRole() in ['admin', 'editor'];
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Engineering roles: manager, team_lead, engineer, technician
    function isManager() {
      return isAuthenticated() && getTeamRole() == 'manager';
    }

    function isTeamLead() {
      return isAuthenticated() && getTeamRole() in ['manager', 'team_lead'];
    }

    function isEngineer() {
      return isAuthenticated() && getTeamRole() in ['manager', 'team_lead', 'engineer'];
    }

    // ============================================================
    // NOTE: Global read rule REMOVED.
    // Each collection now defines its own read permissions.
    // ============================================================

    // ============================================================
    // COLLECTIONS WITH PER-COLLECTION READ/WRITE RULES
    // ============================================================

    // --- users_roles --- [FROZEN]
    // Legacy RBAC collection. Read-only for backward compatibility.
    // All RBAC writes now go to users/{uid}.rbacRole
    match /users_roles/{userId} {
      allow read: if isAuthenticated();
      // All write operations disabled — collection is frozen
    }

    // --- users (extended profiles) ---
    // HARDENED: Users can update their OWN profile EXCEPT privilege fields.
    // rbacRole, teamRole, and active can ONLY be set by admins.
    // This prevents self-escalation (a viewer promoting themselves to admin).
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId
        && (!request.resource.data.keys().hasAny(['rbacRole'])
            || request.resource.data.rbacRole == 'viewer');
      allow update: if isAdmin()
        || (isOwner(userId)
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['rbacRole', 'teamRole', 'active']));
      allow delete: if isAdmin();
    }

    // --- proyectos_bom ---
    match /proyectos_bom/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // --- catalogo_maestro ---
    match /catalogo_maestro/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // --- items_bom ---
    match /items_bom/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // --- marcas, categorias, proveedores ---
    match /marcas/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    match /categorias/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    match /proveedores/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // ============================================================
    // ENGINEERING MANAGEMENT COLLECTIONS
    // ============================================================

    // --- projects (engineering projects) ---
    match /projects/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor();
      allow delete: if isAdmin();

      // --- stations (sub-collection) ---
      match /stations/{stationId} {
        allow read: if isAuthenticated();
        allow create, update: if isEditor();
        allow delete: if isAdmin();
      }
    }

    // --- tasks ---
    // HARDENED V2:
    //   - READ: all authenticated (team needs visibility)
    //   - CREATE: editors+ only
    //   - UPDATE: editors+ can update non-workflow fields.
    //     Workflow fields (status, completedDate, etc.) are BLOCKED —
    //     only transitionTaskStatus Cloud Function (Admin SDK) can change them.
    //   - DELETE: admin only
    match /tasks/{docId} {
      allow read: if isAuthenticated();
      allow create: if isEditor();
      allow update: if isEditor()
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['status', 'completedDate', 'completedAt', 'reopenedAt', 'reopenedBy', 'updatedBy']);
      allow delete: if isAdmin();

      // --- activityLog (sub-collection) ---
      // HARDENED: APPEND-ONLY from client.
      //   - CREATE: authenticated users (logs task events)
      //   - READ: authenticated users
      //   - UPDATE/DELETE: admin only (corrective maintenance)
      // Normal users should NOT edit or delete activity history.
      match /activityLog/{logId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAdmin();
      }

      // --- comments (sub-collection) ---
      // Task comments — any authenticated user can add/read.
      // Only the comment author can edit/delete their own comments.
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated()
          && resource.data.userId == request.auth.uid;
      }
    }

    // --- activityLog collectionGroup ---
    // For cross-task activity timeline queries.
    // HARDENED: read-only + append-only from client. Admin for updates/deletes.
    match /{path=**}/activityLog/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // --- subtasks ---
    // HARDENED V2:
    //   - CREATE: editors+ only (aligned with task creation)
    //   - UPDATE: editors+ only
    //   - DELETE: admin only
    match /subtasks/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // --- timeLogs ---
    // Source of truth for hours.
    // Users can create their own time logs.
    // Users can update/delete their own logs; admins can update/delete any.
    match /timeLogs/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // --- delayCauses (configurable list) ---
    match /delayCauses/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- delays ---
    // Authenticated users can report a delay.
    // Creator or admin can update. Admin only deletes.
    match /delays/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // --- risks ---
    // System-managed (Cloud Functions or admin)
    match /risks/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- dailyReports ---
    match /dailyReports/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- taskTypes ---
    match /taskTypes/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- settings ---
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- auditLogs ---
    // Immutable: only system/admin can create. No updates or deletes.
    match /auditLogs/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    // --- weeklyPlanItems ---
    // HARDENED V2:
    //   - READ: all authenticated (managers need team visibility)
    //   - CREATE: authenticated, but createdBy MUST match the user
    //   - UPDATE/DELETE: only the item creator (createdBy) or admin
    // Field: `assignedTo` is the task assignee; `createdBy` is the planner owner.
    match /weeklyPlanItems/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // --- scheduledTimerEvents ---
    // Written by Firestore triggers (Admin SDK). Admin only from client.
    match /scheduledTimerEvents/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- taskDependencies ---
    // HARDENED: Only editors+ can manage task dependencies (Gantt linking).
    match /taskDependencies/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // ============================================================
    // MANAGEMENT INTELLIGENCE COLLECTIONS
    // ============================================================

    // --- auditFindings ---
    match /auditFindings/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- auditEvents ---
    // IMMUTABLE audit trail — append-only.
    match /auditEvents/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['eventType', 'timestamp', 'userId'])
        && request.resource.data.userId == request.auth.uid;
      // NO update or delete — immutable trail
    }

    // --- analyticsSnapshots ---
    match /analyticsSnapshots/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- aiInsights ---
    match /aiInsights/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- managementBriefs ---
    match /managementBriefs/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- notifications ---
    // User-scoped. Users can read/mark-as-read their own only.
    match /notifications/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // AUTOMATION OPERATIONS & ACCOUNTABILITY
    // ============================================================
    //
    // All automation collections are admin-only from the client.
    // Cloud Functions (Admin SDK) bypass these rules.
    //

    match /automationRoutines/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /automationRuns/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /automationMetricsDaily/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /operationIncidents/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /telegramSessions/{docId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /telegramReports/{docId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /telegramEscalations/{docId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /telegramBotLogs/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      // NO update or delete — append-only
    }

    match /telegramDeliveries/{docId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // ANALYTICS ENGINE
    // ============================================================

    match /operationalKpiSnapshots/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /userOperationalScores/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /routineOperationalScores/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /teamOperationalSummaries/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /operationalRiskFlags/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /operationalRecommendations/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /analyticsRefreshLogs/{docId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /aiExecutions/{docId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // OPTIMIZATION ENGINE
    // ============================================================

    match /optimizationOpportunities/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /optimizationSimulations/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /operationalPlans/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /appliedRecommendations/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /optimizationHistory/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      // NO update or delete — append-only
    }

    // ============================================================
    // TELEGRAM LINK CODES
    // ============================================================

    match /telegramLinkCodes/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // V5 FOUNDATION
    // ============================================================

    match /milestones/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isEditor();
    }

    match /workAreas/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    match /workAreaTypes/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    match /milestoneTypes/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // --- auditTrail ---
    // IMMUTABLE, APPEND-ONLY
    match /auditTrail/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // NO update or delete — immutable trail
    }

    // --- aiGovernance ---
    match /aiGovernance/{docId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- scoreSnapshots ---
    // Append-only score history
    match /scoreSnapshots/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // NO update or delete — immutable history
    }

    // --- resourceAssignments ---
    match /resourceAssignments/{docId} {
      allow read: if isAuthenticated();
      allow create: if isEditor();
      allow update: if isEditor();
      allow delete: if isAdmin();
    }

  }
}
