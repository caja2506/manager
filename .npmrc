# ── AutoBOM Pro — npm security configuration ──
# Ejecutar auditoría automática en cada install
audit=true
# Desactivar mensajes de funding (ruido innecesario)
fund=false
# Usar exact versions al instalar nuevas deps (evita rangos inesperados)
save-exact=true
# Nota: NO activar ignore-scripts por defecto (puede romper pdfjs-dist, etc.)
# Usar --ignore-scripts solo al probar paquetes desconocidos manualmente.
